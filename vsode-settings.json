{
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.formatOnSave": true,
	"editor.renderWhitespace": "none",
	"editor.wordWrap": "on",
	"editor.fontFamily": "Monolisa Nerd Font",
	"editor.fontWeight": "500",
	"symbols.hidesExplorerArrows": false,
	"editor.inlayHints.enabled": "off",
	"editor.guides.bracketPairsHorizontal": false,
	"editor.minimap.enabled": false,
	"editor.tabSize": 2,
	"editor.stickyScroll.enabled": true,
	"editor.unicodeHighlight.ambiguousCharacters": false,
	"editor.codeActionsOnSave": {
		"source.fixAll": false,
		"source.sortImports": true
	},
	"editor.suggest.insertMode": "replace",
	"editor.suggest.snippetsPreventQuickSuggestions": false,
	"editor.snippetSuggestions": "top",
	"editor.hideCursorInOverviewRuler": true,
	"editor.scrollbar.horizontal": "hidden",
	"editor.scrollbar.vertical": "hidden",
	"editor.occurrencesHighlight": false,
	"editor.peekWidgetDefaultFocus": "editor",
	"editor.cursorBlinking": "phase",
	"editor.guides.indentation": false,
	"editor.glyphMargin": false,
	"editor.lineNumbers": "off",
	"editor.showFoldingControls": "never",
	"editor.cursorWidth": 5,
	"editor.cursorSmoothCaretAnimation": "on",
	"editor.renderLineHighlight": "none",
	"editor.bracketPairColorization.enabled": false,
	"editor.guides.highlightActiveBracketPair": false,
	"workbench.startupEditor": "none",
	"emmet.includeLanguages": {
		"javascript": "javascriptreact",
		"typescript": "typescriptreact"
	},
	"terminal.integrated.showExitAlert": false,
	"terminal.integrated.profiles.windows": {
		"PowerShell": { "source": "PowerShell", "icon": "terminal-powershell" },
		"Git Bash": { "source": "Git Bash" }
	},
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.defaultProfile.windows": "Git Bash",
	"terminal.integrated.gpuAcceleration": "off",
	"terminal.integrated.fontSize": 14,
	"terminal.integrated.fontWeight": "500",
	"terminal.external.windowsExec": "C:\\Users\\Andrew\\AppData\\Local\\Microsoft\\WindowsApps\\wt.exe",
	"explorer.confirmDelete": false,
	"extensions.autoCheckUpdates": false,
	"update.enableWindowsBackgroundUpdates": false,
	"liveSassCompile.settings.formats": [{ "format": "expanded", "extensionName": ".css", "savePath": "/public/css" }],
	"explorer.confirmDragAndDrop": false,
	"better-comments.highlightPlainText": true,
	"javascript.updateImportsOnFileMove.enabled": "always",
	"scm.diffDecorationsIgnoreTrimWhitespace": "true",
	"prettier.useTabs": true,
	"prettier.singleQuote": true,
	"prettier.jsxSingleQuote": true,
	"prettier.semi": false,
	"prettier.arrowParens": "avoid",
	"typescript.preferences.quoteStyle": "single",
	"typescript.updateImportsOnFileMove.enabled": "always",
	"breadcrumbs.enabled": false,
	"scm.diffDecorations": "gutter",
	"scm.diffDecorationsGutterVisibility": "hover",
	"scm.diffDecorationsGutterWidth": 1,
	"problems.defaultViewMode": "table",
	"tailwindCSS.emmetCompletions": true,
	"editor.overviewRulerBorder": false,
	"window.title": " ",
	"workbench.layoutControl.enabled": false,
	"window.menuBarVisibility": "toggle",
	"telemetry.telemetryLevel": "off",
	"search.exclude": {
		"**/node_modules": true,
		"**/bower_components": true,
		"**/env": true,
		"**/venv": true
	},
	"workbench.colorTheme": "Noir Owl",
	"workbench.iconTheme": "symbols",
	"thunder-client.requestLayout": "Top/Bottom",
	"thunder-client.sidebar.hideDateModified": true,
	"thunder-client.editorFontSize": 18,
	"codesnap.showWindowControls": false,
	"color-highlight.markRuler": false,
	"workbench.editor.enablePreview": false,
	"explorer.compactFolders": false,
	"workbench.tree.renderIndentGuides": "none",
	"explorer.decorations.colors": false,
	"explorer.openEditors.visible": 0,
	"settings.cycle": [
		{
			"id": "lineNumbers",
			"values": [{ "editor.lineNumbers": "off" }, { "editor.lineNumbers": "on" }]
		}
	],
	"vscode_custom_css.imports": ["file:///C:/Users/Andrew/.vscode/hide-title-bar.css"],
	"editor.padding.top": 20,
	"workbench.sideBar.location": "right",
	"better-comments.tags": [
		{
			"tag": "-",
			"color": "#fcf6bd",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "transparent",
			"bold": false,
			"italic": false
		},
		{
			"tag": "bug",
			"color": "#fff",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "#be2525",
			"bold": true,
			"italic": false
		},
		{
			"tag": "?",
			"color": "#fff",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "#173FCF66",
			"bold": true,
			"italic": false
		},
		{
			"tag": "todo",
			"color": "#fff",
			"strikethrough": false,
			"underline": false,
			"backgroundColor": "#ffb703bb",
			"bold": true,
			"italic": false
		}
	],
	"prettier.printWidth": 120,
	"workbench.statusBar.visible": false,
	"scm.diffDecorationsGutterAction": "none",
	"editor.lineHeight": 2,
	"editor.fontSize": 16,
	"editor.fontLigatures": true,
	"fontsy.defaultEditorFontSize": 16,
	"fontsy.defaultTerminalFontSize": 14,
	"fontsy.step": 0.5,
	"liveSassCompile.settings.showOutputWindowOn": "Warning",
	"workbench.activityBar.visible": false
}
